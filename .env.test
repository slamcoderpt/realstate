# Stack Supabase local. Estas chaves sao os JWTs demo publicos do Supabase local
# (iss: supabase-demo), identicos em todas as maquinas — por isso sao commitadas.
# NUNCA colocar aqui chaves de um projecto cloud.
#
# Nota: a porta e 54421 (e nao a default 54321) porque outro projecto local nesta
# maquina ja ocupa a gama 543xx. Ver supabase/config.toml.
SUPABASE_URL=http://127.0.0.1:54421
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU
# Ligacao directa ao Postgres. Necessaria porque o PostgREST nao expoe TRUNCATE e
# porque so uma ligacao directa alcanca o caminho do owner (postgres), que a API
# nunca atinge — e e o owner que o trigger de imutabilidade do audit_log trava.
# Porta 54422 (ver nota sobre a gama 543xx acima).
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54422/postgres
