# Copiar para .env.local e preencher com os valores do stack local (`supabase status`)
# ou do projecto cloud. O .env.local e gitignored e nunca deve ser commitado.

# URL da API Supabase. Localmente: http://127.0.0.1:54421 (ver supabase/config.toml).
NEXT_PUBLIC_SUPABASE_URL=
# Chave anon (publica, exposta ao browser). Sujeita a RLS.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Chave service_role: IGNORA RLS. Apenas server-side. Nunca expor ao cliente.
SUPABASE_SERVICE_ROLE_KEY=
# Ligacao directa ao Postgres (apenas testes). Localmente:
# postgresql://postgres:postgres@127.0.0.1:54422/postgres (ver `supabase status`).
SUPABASE_DB_URL=

# --- Email (SMTP Microsoft 365) ---
# Envio sincrono nas Server Actions (sem fila/poller). Deixar vazio em dev/CI: os
# testes injectam um transport mock e nao tocam num SMTP real.
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Remetente. Se vazio, cai no SMTP_USER.
SMTP_FROM=

# URL publica da app, usada para construir links absolutos nos emails de convite.
# Localmente: http://127.0.0.1:3000
NEXT_PUBLIC_APP_URL=
